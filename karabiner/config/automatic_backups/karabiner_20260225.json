{
  "profiles": [
    {
      "name": "Default profile",
      "selected": true,
      "virtual_hid_keyboard": { "keyboard_type_v2": "iso" },
      "complex_modifications": {
        "rules": [
          {
            "description": "Caps: single=RU<->lastLatin (US/LV), double=US<->LV (uses F18)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "caps_lock" },

                "conditions": [
                  { "type": "variable_unless", "name": "caps_waiting_second", "value": 1 }
                ],

                "to": [
                  { "set_variable": { "name": "caps_waiting_second", "value": 1 } }
                ],

                "to_delayed_action": {
                  "to_if_invoked": [
                    { "set_variable": { "name": "caps_waiting_second", "value": 0 } },
                    { "key_code": "f18" }
                  ],
                  "to_if_canceled": [
                    { "set_variable": { "name": "caps_waiting_second", "value": 0 } }
                  ]
                },

                "parameters": {
                  "basic.to_delayed_action_delay_milliseconds": 280
                }
              },

              {
                "type": "basic",
                "from": { "key_code": "caps_lock" },
                "conditions": [
                  { "type": "variable_if", "name": "caps_waiting_second", "value": 1 }
                ],
                "to": [
                  { "set_variable": { "name": "caps_waiting_second", "value": 0 } },

                  { "set_variable": { "name": "kb_last_latin", "value": 1 } },
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.US" } }
                ]
              },

              {
                "type": "basic",
                "from": { "key_code": "caps_lock" },
                "conditions": [
                  { "type": "variable_if", "name": "caps_waiting_second", "value": 1 },
                  { "type": "input_source_if", "input_sources": [{ "input_source_id": "com.apple.keylayout.US" }] }
                ],
                "to": [
                  { "set_variable": { "name": "caps_waiting_second", "value": 0 } },
                  { "set_variable": { "name": "kb_last_latin", "value": 2 } },
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.Latvian" } }
                ]
              },

              {
                "type": "basic",
                "from": { "key_code": "caps_lock" },
                "conditions": [
                  { "type": "variable_if", "name": "caps_waiting_second", "value": 1 },
                  { "type": "input_source_if", "input_sources": [{ "input_source_id": "com.apple.keylayout.Latvian" }] }
                ],
                "to": [
                  { "set_variable": { "name": "caps_waiting_second", "value": 0 } },
                  { "set_variable": { "name": "kb_last_latin", "value": 1 } },
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.US" } }
                ]
              },

              /* ---- SINGLE action happens on F18 (fired after delay if no second press) ---- */

              {
                "type": "basic",
                "from": { "key_code": "f18" },
                "conditions": [
                  { "type": "input_source_if", "input_sources": [{ "input_source_id": "com.apple.keylayout.US" }] }
                ],
                "to": [
                  { "set_variable": { "name": "kb_last_latin", "value": 1 } },
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.Russian" } }
                ]
              },

              {
                "type": "basic",
                "from": { "key_code": "f18" },
                "conditions": [
                  { "type": "input_source_if", "input_sources": [{ "input_source_id": "com.apple.keylayout.Latvian" }] }
                ],
                "to": [
                  { "set_variable": { "name": "kb_last_latin", "value": 2 } },
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.Russian" } }
                ]
              },

              {
                "type": "basic",
                "from": { "key_code": "f18" },
                "conditions": [
                  { "type": "input_source_if", "input_sources": [{ "input_source_id": "com.apple.keylayout.Russian" }] },
                  { "type": "variable_if", "name": "kb_last_latin", "value": 2 }
                ],
                "to": [
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.Latvian" } }
                ]
              },

              {
                "type": "basic",
                "from": { "key_code": "f18" },
                "conditions": [
                  { "type": "input_source_if", "input_sources": [{ "input_source_id": "com.apple.keylayout.Russian" }] },
                  { "type": "variable_unless", "name": "kb_last_latin", "value": 2 }
                ],
                "to": [
                  { "select_input_source": { "input_source_id": "com.apple.keylayout.US" } }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}